datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model DashboardSession {
  id           String   @id @default(cuid())
  discordId    String
  username     String
  globalName   String?
  avatar       String?
  accessToken  String
  refreshToken String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  lastSeenAt   DateTime @updatedAt

  @@index([discordId])
  @@index([expiresAt])
}

model GuildSubscription {
  id               String   @id @default(cuid())
  guildId          String   @unique
  plan             String   @default("FREE")
  active           Boolean  @default(false)
  source           String   @default("bot_sync")
  premiumTier      String?
  premiumExpiresAt DateTime?
  stripeCustomerId String?
  stripeSubId      String?
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([active])
  @@index([premiumExpiresAt])
}

model DashboardAuditEvent {
  id          String   @id @default(cuid())
  guildId     String?
  actorUserId String?
  actorTag    String?
  area        String
  action      String
  severity    String   @default("info")
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([guildId, createdAt])
  @@index([area, createdAt])
  @@index([actorUserId, createdAt])
}

model GuildDiscoveryCache {
  cacheKey   String   @id
  kind       String
  payload    String
  expiresAt  DateTime
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([kind, expiresAt])
}
