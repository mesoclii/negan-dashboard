"use client"; import { useEffect, useState } from "react";
export default function EconomyPage(){const[g,setG]=useState("");const[econ,setEcon]=useState(false);const[bday,setBday]=useState(false);const[msg,setMsg]=useState("");
useEffect(()=>{const q=new URLSearchParams(window.location.search).get("guildId")||localStorage.getItem("activeGuildId")||"";setG(q);if(q){localStorage.setItem("activeGuildId",q);fetch(`/api/bot/dashboard-config?guildId=${encodeURIComponent(q)}`).then(r=>r.json()).then(j=>{setEcon(!!j?.config?.features?.economyEnabled);setBday(!!j?.config?.features?.birthdayEnabled);});}},[]);
async function save(){const r=await fetch("/api/bot/dashboard-config",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({guildId:g,patch:{features:{economyEnabled:econ,birthdayEnabled:bday}}})});const j=await r.json().catch(()=>({}));setMsg(r.ok?"Saved.":(j?.error||"Save failed"));}
return <div style={{color:"#ff5252",padding:24}}><h1>ECONOMY</h1><label><input type="checkbox" checked={econ} onChange={e=>setEcon(e.target.checked)}/> economyEnabled</label><br/><label><input type="checkbox" checked={bday} onChange={e=>setBday(e.target.checked)}/> birthdayEnabled</label><br/><button onClick={save}>Save Economy</button><p>{msg}</p></div>}
