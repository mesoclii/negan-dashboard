"use client"; import { useEffect, useState } from "react";
export default function GamesPage(){const[g,setG]=useState("");const[rare,setRare]=useState(false);const[poke,setPoke]=useState(false);const[msg,setMsg]=useState("");
useEffect(()=>{const q=new URLSearchParams(window.location.search).get("guildId")||localStorage.getItem("activeGuildId")||"";setG(q);if(q){localStorage.setItem("activeGuildId",q);fetch(`/api/bot/dashboard-config?guildId=${encodeURIComponent(q)}`).then(r=>r.json()).then(j=>{setRare(!!j?.config?.features?.rareDropEnabled);setPoke(!!j?.config?.features?.pokemonEnabled);});}},[]);
async function save(){const r=await fetch("/api/bot/dashboard-config",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({guildId:g,patch:{features:{rareDropEnabled:rare,pokemonEnabled:poke}}})});const j=await r.json().catch(()=>({}));setMsg(r.ok?"Saved.":(j?.error||"Save failed"));}
return <div style={{color:"#ff5252",padding:24}}><h1>GAMES</h1><label><input type="checkbox" checked={rare} onChange={e=>setRare(e.target.checked)}/> rareDropEnabled</label><br/><label><input type="checkbox" checked={poke} onChange={e=>setPoke(e.target.checked)}/> pokemonEnabled (private guild only)</label><br/><button onClick={save}>Save Games</button><p>{msg}</p></div>}
